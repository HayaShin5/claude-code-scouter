{
  "name": "claude-danger-indicator",
  "displayName": "Claude Danger Indicator",
  "description": "Shows danger level of commands Claude Code asks to execute",
  "version": "0.0.1",
  "publisher": "HayaShin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hashi-o/claude-danger-indicator"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claude-danger-indicator.showDetails",
        "title": "Claude Danger: Show Details"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "node --test out/test/**/*.test.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
