{
  "name": "claude-code-scouter",
  "displayName": "Claude Code Scouter",
  "description": "Scans and displays danger level of commands Claude Code asks to execute",
  "version": "0.1.0",
  "publisher": "HayaShin5",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/HayaShin5/claude-code-scouter"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claude-code-scouter.showDetails",
        "title": "Claude Code Scouter: Show Details"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "node --test out/test/**/*.test.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
